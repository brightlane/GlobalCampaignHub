<svg viewBox="0 0 1200 630" xmlns="http://www.w3.org/2000/svg" width="1200" height="630">
  <defs>
    <!-- Background gradient -->
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%"   stop-color="#0a0b0d"/>
      <stop offset="100%" stop-color="#111318"/>
    </linearGradient>

    <!-- Accent glow top right -->
    <radialGradient id="glow1" cx="85%" cy="15%" r="40%">
      <stop offset="0%"   stop-color="#e8ff47" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="#e8ff47" stop-opacity="0"/>
    </radialGradient>

    <!-- Accent glow bottom left -->
    <radialGradient id="glow2" cx="15%" cy="85%" r="35%">
      <stop offset="0%"   stop-color="#47ffb8" stop-opacity="0.08"/>
      <stop offset="100%" stop-color="#47ffb8" stop-opacity="0"/>
    </radialGradient>

    <!-- Grid pattern -->
    <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
      <path d="M 60 0 L 0 0 0 60" fill="none" stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
    </pattern>

    <!-- Noise texture filter -->
    <filter id="noise">
      <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="4" stitchTiles="stitch"/>
      <feColorMatrix type="saturate" values="0"/>
      <feBlend in="SourceGraphic" mode="overlay" result="blend"/>
      <feComposite in="blend" in2="SourceGraphic" operator="in"/>
    </filter>

    <!-- Clip path for rounded corners -->
    <clipPath id="rounded">
      <rect width="1200" height="630" rx="0"/>
    </clipPath>
  </defs>

  <!-- Base background -->
  <rect width="1200" height="630" fill="url(#bg)"/>

  <!-- Grid overlay -->
  <rect width="1200" height="630" fill="url(#grid)"/>

  <!-- Glow effects -->
  <rect width="1200" height="630" fill="url(#glow1)"/>
  <rect width="1200" height="630" fill="url(#glow2)"/>

  <!-- Diagonal accent line top-right -->
  <line x1="900" y1="0" x2="1200" y2="180" stroke="rgba(232,255,71,0.08)" stroke-width="1"/>
  <line x1="980" y1="0" x2="1200" y2="140" stroke="rgba(232,255,71,0.05)" stroke-width="1"/>
  <line x1="820" y1="0" x2="1200" y2="240" stroke="rgba(232,255,71,0.04)" stroke-width="1"/>

  <!-- Diagonal accent line bottom-left -->
  <line x1="0" y1="420" x2="300" y2="630" stroke="rgba(71,255,184,0.06)" stroke-width="1"/>
  <line x1="0" y1="480" x2="200" y2="630" stroke="rgba(71,255,184,0.04)" stroke-width="1"/>

  <!-- Left accent bar -->
  <rect x="72" y="80" width="4" height="470" fill="rgba(232,255,71,0.15)" rx="2"/>

  <!-- Top left — verified badge -->
  <rect x="96" y="88" width="148" height="28" rx="14" fill="rgba(232,255,71,0.12)" stroke="rgba(232,255,71,0.3)" stroke-width="1"/>
  <text x="170" y="106" font-family="'Courier New', monospace" font-size="11" font-weight="700" fill="#e8ff47" text-anchor="middle" letter-spacing="2">✓ VERIFIED</text>

  <!-- Main headline -->
  <text x="96" y="200" font-family="Georgia, serif" font-size="72" font-weight="700" fill="#e8e9ed" letter-spacing="-2">Global</text>
  <text x="96" y="285" font-family="Georgia, serif" font-size="72" font-weight="700" fill="#e8ff47" letter-spacing="-2">Campaign</text>
  <text x="96" y="370" font-family="Georgia, serif" font-size="72" font-weight="700" fill="#e8e9ed" letter-spacing="-2">Hub</text>

  <!-- Subheadline -->
  <text x="96" y="420" font-family="'Helvetica Neue', Arial, sans-serif" font-size="22" fill="#8a8d99" letter-spacing="0.5">68 Verified Merchants · 20 Languages · 7M+ Users</text>

  <!-- Separator line -->
  <line x1="96" y1="445" x2="560" y2="445" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>

  <!-- Bottom stats row -->
  <!-- Stat 1 -->
  <text x="96" y="490" font-family="Georgia, serif" font-size="36" font-weight="700" fill="#e8ff47">68</text>
  <text x="96" y="515" font-family="'Helvetica Neue', Arial, sans-serif" font-size="13" fill="#555866" letter-spacing="1">MERCHANTS</text>

  <!-- Divider -->
  <line x1="200" y1="470" x2="200" y2="525" stroke="rgba(255,255,255,0.07)" stroke-width="1"/>

  <!-- Stat 2 -->
  <text x="218" y="490" font-family="Georgia, serif" font-size="36" font-weight="700" fill="#47ffb8">20</text>
  <text x="218" y="515" font-family="'Helvetica Neue', Arial, sans-serif" font-size="13" fill="#555866" letter-spacing="1">LANGUAGES</text>

  <!-- Divider -->
  <line x1="330" y1="470" x2="330" y2="525" stroke="rgba(255,255,255,0.07)" stroke-width="1"/>

  <!-- Stat 3 -->
  <text x="348" y="490" font-family="Georgia, serif" font-size="36" font-weight="700" fill="#e8e9ed">9</text>
  <text x="348" y="515" font-family="'Helvetica Neue', Arial, sans-serif" font-size="13" fill="#555866" letter-spacing="1">CATEGORIES</text>

  <!-- Divider -->
  <line x1="430" y1="470" x2="430" y2="525" stroke="rgba(255,255,255,0.07)" stroke-width="1"/>

  <!-- Stat 4 -->
  <text x="448" y="490" font-family="Georgia, serif" font-size="36" font-weight="700" fill="#e8e9ed">007949</text>
  <text x="448" y="515" font-family="'Helvetica Neue', Arial, sans-serif" font-size="13" fill="#555866" letter-spacing="1">LINKCONNECTOR</text>

  <!-- Bottom URL -->
  <text x="96" y="575" font-family="'Courier New', monospace" font-size="14" fill="#555866" letter-spacing="1">brightlane.github.io/GlobalCampaignHub</text>

  <!-- RIGHT SIDE — Category pills -->
  <!-- Background panel -->
  <rect x="680" y="60" width="460" height="510" rx="16" fill="rgba(17,19,24,0.8)" stroke="rgba(255,255,255,0.07)" stroke-width="1"/>

  <!-- Panel header -->
  <text x="910" y="105" font-family="'Helvetica Neue', Arial, sans-serif" font-size="12" font-weight="700" fill="#555866" text-anchor="middle" letter-spacing="2">MERCHANT CATEGORIES</text>
  <line x1="700" y1="118" x2="1120" y2="118" stroke="rgba(255,255,255,0.07)" stroke-width="1"/>

  <!-- Category rows — 9 categories with counts and accent colors -->
  <!-- Tax -->
  <rect x="700" y="132" width="420" height="44" rx="8" fill="rgba(232,255,71,0.04)"/>
  <rect x="700" y="132" width="3" height="44" rx="1" fill="#e8ff47"/>
  <text x="718" y="152" font-family="'Helvetica Neue', Arial, sans-serif" font-size="14" font-weight="600" fill="#e8e9ed">Tax Services</text>
  <text x="718" y="169" font-family="'Helvetica Neue', Arial, sans-serif" font-size="11" fill="#555866">E-file · TaxExtension · ezTaxReturn · E TAX</text>
  <text x="1105" y="158" font-family="Georgia, serif" font-size="20" font-weight="700" fill="#e8ff47" text-anchor="end">4</text>

  <!-- Software -->
  <rect x="700" y="182" width="420" height="44" rx="8" fill="rgba(71,255,184,0.03)"/>
  <rect x="700" y="182" width="3" height="44" rx="1" fill="#47ffb8"/>
  <text x="718" y="202" font-family="'Helvetica Neue', Arial, sans-serif" font-size="14" font-weight="600" fill="#e8e9ed">Software</text>
  <text x="718" y="219" font-family="'Helvetica Neue', Arial, sans-serif" font-size="11" fill="#555866">NordVPN · Filmora · PDFelement · Tenorshare +12</text>
  <text x="1105" y="208" font-family="Georgia, serif" font-size="20" font-weight="700" fill="#47ffb8" text-anchor="end">16</text>

  <!-- Education -->
  <rect x="700" y="232" width="420" height="44" rx="8" fill="rgba(255,107,71,0.03)"/>
  <rect x="700" y="232" width="3" height="44" rx="1" fill="#ff6b47"/>
  <text x="718" y="252" font-family="'Helvetica Neue', Arial, sans-serif" font-size="14" font-weight="600" fill="#e8e9ed">Education</text>
  <text x="718" y="269" font-family="'Helvetica Neue', Arial, sans-serif" font-size="11" fill="#555866">BoardVitals · Surgent · PM Training · HRCP +6</text>
  <text x="1105" y="258" font-family="Georgia, serif" font-size="20" font-weight="700" fill="#ff6b47" text-anchor="end">10</text>

  <!-- Pet Care -->
  <rect x="700" y="282" width="420" height="44" rx="8" fill="rgba(232,255,71,0.02)"/>
  <rect x="700" y="282" width="3" height="44" rx="1" fill="#e8ff47"/>
  <text x="718" y="302" font-family="'Helvetica Neue', Arial, sans-serif" font-size="14" font-weight="600" fill="#e8e9ed">Pet Care</text>
  <text x="718" y="319" font-family="'Helvetica Neue', Arial, sans-serif" font-size="11" fill="#555866">CanadaPetCare · BestVetCare · BudgetPetCare +2</text>
  <text x="1105" y="308" font-family="Georgia, serif" font-size="20" font-weight="700" fill="#e8ff47" text-anchor="end">5</text>

  <!-- Health -->
  <rect x="700" y="332" width="420" height="44" rx="8" fill="rgba(71,255,184,0.02)"/>
  <rect x="700" y="332" width="3" height="44" rx="1" fill="#47ffb8"/>
  <text x="718" y="352" font-family="'Helvetica Neue', Arial, sans-serif" font-size="14" font-weight="600" fill="#e8e9ed">Health &amp; Wellness</text>
  <text x="718" y="369" font-family="'Helvetica Neue', Arial, sans-serif" font-size="11" fill="#555866">Personalabs · Nurse Jamie · Ayurveda Experience</text>
  <text x="1105" y="358" font-family="Georgia, serif" font-size="20" font-weight="700" fill="#47ffb8" text-anchor="end">3</text>

  <!-- Auto -->
  <rect x="700" y="382" width="420" height="44" rx="8" fill="rgba(232,255,71,0.02)"/>
  <rect x="700" y="382" width="3" height="44" rx="1" fill="#e8ff47"/>
  <text x="718" y="402" font-family="'Helvetica Neue', Arial, sans-serif" font-size="14" font-weight="600" fill="#e8e9ed">Auto &amp; Imports</text>
  <text x="718" y="419" font-family="'Helvetica Neue', Arial, sans-serif" font-size="11" fill="#555866">Maxpeedingrods US · Maxpeedingrods AU · La Fuente</text>
  <text x="1105" y="408" font-family="Georgia, serif" font-size="20" font-weight="700" fill="#e8ff47" text-anchor="end">3</text>

  <!-- Print -->
  <rect x="700" y="432" width="420" height="44" rx="8" fill="rgba(71,255,184,0.02)"/>
  <rect x="700" y="432" width="3" height="44" rx="1" fill="#47ffb8"/>
  <text x="718" y="452" font-family="'Helvetica Neue', Arial, sans-serif" font-size="14" font-weight="600" fill="#e8e9ed">Print &amp; Signs</text>
  <text x="718" y="469" font-family="'Helvetica Neue', Arial, sans-serif" font-size="11" fill="#555866">BuildASign · EasyCanvas · Etching Expressions +3</text>
  <text x="1105" y="458" font-family="Georgia, serif" font-size="20" font-weight="700" fill="#47ffb8" text-anchor="end">6</text>

  <!-- Hardware -->
  <rect x="700" y="482" width="420" height="44" rx="8" fill="rgba(232,255,71,0.02)"/>
  <rect x="700" y="482" width="3" height="44" rx="1" fill="#e8ff47"/>
  <text x="718" y="502" font-family="'Helvetica Neue', Arial, sans-serif" font-size="14" font-weight="600" fill="#e8e9ed">Hardware</text>
  <text x="718" y="519" font-family="'Helvetica Neue', Arial, sans-serif" font-size="11" fill="#555866">Trademark Hardware · Soundproofing · Fieldtex +2</text>
  <text x="1105" y="508" font-family="Georgia, serif" font-size="20" font-weight="700" fill="#e8ff47" text-anchor="end">5</text>

  <!-- Lifestyle -->
  <rect x="700" y="532" width="420" height="44" rx="8" fill="rgba(71,255,184,0.03)"/>
  <rect x="700" y="532" width="3" height="44" rx="1" fill="#47ffb8"/>
  <text x="718" y="552" font-family="'Helvetica Neue', Arial, sans-serif" font-size="14" font-weight="600" fill="#e8e9ed">Lifestyle</text>
  <text x="718" y="569" font-family="'Helvetica Neue', Arial, sans-serif" font-size="11" fill="#555866">HalloweenCostumes · Survey Junkie · BGM Girl +15</text>
  <text x="1105" y="558" font-family="Georgia, serif" font-size="20" font-weight="700" fill="#47ffb8" text-anchor="end">18</text>

  <!-- Bottom border accent -->
  <rect x="0" y="618" width="1200" height="12" fill="url(#bg)"/>
  <rect x="0" y="624" width="600" height="3" fill="#e8ff47" opacity="0.6"/>
  <rect x="600" y="624" width="600" height="3" fill="#47ffb8" opacity="0.4"/>
</svg>
